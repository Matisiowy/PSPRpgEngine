{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://psprpg.dev/schemas/project-v2.json",
  "title": "PSP RPG Studio project manifest",
  "type": "object",
  "required": ["formatVersion", "projectId", "name", "startupScene", "sceneFiles"],
  "properties": {
    "formatVersion": { "const": 2 },
    "projectId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "startupScene": { "type": "string", "format": "uuid" },
    "sceneFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "path": { "type": "string", "pattern": "^Scenes/" }
        }
      }
    }
  }
}
